# Backend API base URL — the airportrides-backend service.
# Local: http://localhost:3001    Prod: https://api.airportrides.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Public site URL — used for metadataBase, sitemap, robots, JSON-LD canonicals.
NEXT_PUBLIC_SITE_URL=https://airportrides.com

# Google Analytics 4 measurement ID. Leave blank in local dev to skip GA init.
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Meta (Facebook) Pixel ID. Optional — only set when running paid social ads.
NEXT_PUBLIC_META_PIXEL_ID=

# Brand key consumed by @travel-suite/config to select the brand profile.
NEXT_PUBLIC_BRAND=airportrides
